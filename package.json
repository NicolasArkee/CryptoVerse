{
  "name": "cryptoverse",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:next": "next dev",
    "dev": "run-p db-server:file dev:*",
    "build:next": "next build",
    "build": "next build",
    "start": "next start",
    "db-server:file": "pglite-server --db=local.db --run 'pnpm db:migrate'",
    "db-server:memory": "pglite-server --run 'pnpm db:migrate'",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "dotenv -c -- drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@t3-oss/env-nextjs": "^0.13.10",
    "drizzle-orm": "^0.45.1",
    "next": "^16.1.6",
    "next-intl": "^4.8.3",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electric-sql/pglite-socket": "^0.0.22",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.14",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.9",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.32.1"
}
